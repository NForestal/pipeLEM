FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
	type            zeroGradient;
    }
    outlet
    {
	type            codedFixedValue;
        value    	uniform 0;
        name            OhmLaw;
        codeInclude	#{
            #include "fvCFD.H"
            #include "IOstreams.H"
            #include <vector>
            
            // Define the slope of the ODE
            inline scalar dp (scalar Qt, scalar dQ, scalar pt, scalar R1, scalar R2, scalar tau) {
               return R1*dQ + Qt*((R1 + R2)/tau) - pt/tau;
            }
        #};
        code		#{
            // Access the mesh and patch informations
            const fvMesh& mesh = refCast<const fvMesh>(this->db());
            const fvPatch& boundaryPatch = patch();
            
            // Initialize the pressure field
            operator==(scalarField(patch().size(), 0.0));
            scalarField& p = *this;
            
            // Get the time and time step
            scalar dt = this->db().time().deltaTValue();
            
            // Create Storages
            static scalar pOld;					// Create a storage for pressure(t-1)
            static std::vector<scalar> QStore = {0, 0, 0};	// Create a storage for flow rate last time steps
            
            // Skip First time step
            if (!mesh.foundObject<surfaceScalarField>("phi")) {
               Info << "phi not found, setting p = 0" << endl;
               pOld = 0;
            } 
            else {
               // Access velocity field
               const surfaceScalarField& phi = mesh.lookupObject<surfaceScalarField>("phi");
               const fvsPatchField phiPatch = phi.boundaryField()[boundaryPatch.index()];
               
               // Access transportProperties dictionary
               const IOdictionary& transportProperties = mesh.lookupObject<IOdictionary>("transportProperties");   
               dimensionedScalar rhoDim("rho", transportProperties);
               scalar rho = rhoDim.value();
               
               // Load external variables dictionary from constant directory
               const IOdictionary varsDict(
                   IOobject(
                       "variablesDict",			// The name of the dictionary
                       "constant",			// Location in the case directory
                       mesh,				// Associated database (the mesh for context)
                       IOobject::MUST_READ,		// Ensures it must be read or throws an error
                       IOobject::NO_WRITE		// Writes if the object is modified
                   )
               );
               scalar Res1 = readScalar(varsDict.lookup("Impedance"));
               scalar Res2 = readScalar(varsDict.lookup("Resistor"));
               scalar Cap = readScalar(varsDict.lookup("Capacitor"));
               scalar tau = Res2 * Cap;			// Get time constant
               
               // Get the flow rate
               scalar Q = gSum(phiPatch) / rho;
               if (QStore.back() != Q) {
                  QStore.push_back(Q);
               }
               // Get flow rate variation
               scalar dQ = (QStore[QStore.size()-2] - QStore.back()) / dt;
               
               // Get the Runge-Kutta slope
               scalar k1 = dp(Q, dQ, pOld, Res1, Res2, tau);
               scalar k2 = dp(Q, dQ, pOld + dt * k1/2, Res1, Res2, tau);
               scalar k3 = dp(Q, dQ, pOld + dt * k2/2, Res1, Res2, tau);
               scalar k4 = dp(Q, dQ, pOld + dt * k3, Res1, Res2, tau);
               
               // Time integration (Runge-Kutta)
               scalar pNew = pOld + (k1 + 2 * k2 + 2 * k3 + k4) * dt / 6;
               
               // Apply pressure at boundary
               p = (scalarField(patch().size(), pNew));
               
               // Store previous pressure
               pOld = pNew;	
               
               // Purge flow rate storage
               if (QStore.size() > 3) {
                  QStore.erase(QStore.begin());
               }
            } 
        #};
        codeOptions	#{
            -I$(LIB_SRC)/finiteVolume/lnInclude \
            -I$(LIB_SRC)/meshTools/lnInclude
        #};
        codeLibs	#{
            -lmeshTools \
            -lfiniteVolume
        #};
    }
    interface
    {
        type		zeroGradient;
    }
}

