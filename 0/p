FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
	type            codedFixedValue;
        value    uniform 0;
        name            delayPulse;
        codeInclude	#{
            #include "fvCFD.H"
            #include "IOstreams.H"
            #include <cmath>
        #};
        code		#{
            // Initialize the pressure field
            operator==(scalarField(patch().size(), 0.0));
            scalarField& p = *this;
            
            scalar t = this->db().time().value();		// Time
            scalar pi = M_PI;
            p = (t <= 1.0)? 1.0e-6 : 1.0e-6 * (1 + 0.2 * sin(2*pi*(t-1.0)));
        #};
        codeOptions	#{
            -I$(LIB_SRC)/finiteVolume/lnInclude \
            -I$(LIB_SRC)/meshTools/lnInclude
        #};
        codeLibs	#{
            -lmeshTools \
            -lfiniteVolume
        #};
    }
    outlet
    {
	type            codedFixedValue;
        value    	uniform 0;
        name            OhmLaw;
        codeInclude	#{
            #include "fvCFD.H"
            #include "IOstreams.H"
        #};
        code		#{
            // Access the mesh and patch informations
            const fvMesh& mesh = refCast<const fvMesh>(this->db());
            const fvPatch& boundaryPatch = patch();
            
            // Initialize the pressure field
            operator==(scalarField(patch().size(), 0.0));
            scalarField& p = *this;
            
            // Get the time step
            scalar dt = this->db().time().deltaTValue();
            
            static scalar pOld;				// Create a storage for pressure(t-1)
            
            if (!mesh.foundObject<surfaceScalarField>("phi")) {
               Info << "phi not found, setting p = 0" << endl;
               pOld = 0;
            } 
            else {
               // Access velocity field
               const surfaceScalarField& phi = mesh.lookupObject<surfaceScalarField>("phi");
               const fvsPatchField phiPatch = phi.boundaryField()[boundaryPatch.index()];
               
               // Access transportProperties dictionary
               const IOdictionary& transportProperties = mesh.lookupObject<IOdictionary>("transportProperties");   
               dimensionedScalar rhoDim("rho", transportProperties);
               scalar rho = rhoDim.value();
               
               // Load external variables dictionary from constant directory
               const IOdictionary varsDict(
                   IOobject(
                       "variablesDict",			// The name of the dictionary
                       "constant",			// Location in the case directory
                       mesh,				// Associated database (the mesh for context)
                       IOobject::MUST_READ,		// Ensures it must be read or throws an error
                       IOobject::NO_WRITE		// Writes if the object is modified
                   )
               );
               scalar Res = readScalar(varsDict.lookup("Resistor"));
               scalar Cap = readScalar(varsDict.lookup("Capacitor"));
               scalar tau = Res * Cap;			// Get time constant
               
               // Calculate the flow rate
               scalar Q = gSum(phiPatch);
               
               // Time integration (Euler forward)
               scalar pNew = (pOld + (Q * dt) / (Cap * rho)) * tau / (tau + dt);
               
               p = (scalarField(patch().size(), pNew));	// Apply pressure at boundary
               pOld = pNew;				// Store previous pressure
            } 
        #};
        codeOptions	#{
            -I$(LIB_SRC)/finiteVolume/lnInclude \
            -I$(LIB_SRC)/meshTools/lnInclude
        #};
        codeLibs	#{
            -lmeshTools \
            -lfiniteVolume
        #};
    }
    interface
    {
        type		zeroGradient;
    }
}

