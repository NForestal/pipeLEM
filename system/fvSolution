FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "p|pFinal"
    {
	solver          GAMG;
        tolerance       1e-09;
        relTol          0;
        minIter         1;
        maxIter         1000;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
        scaleCorrection true;
        directSolveCoarsest false;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    };

    "U|UFinal"
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-07;
        relTol          0;
	minIter		1;
    };

    "Phi"
    {
        solver           GAMG;
        smoother	 DIC;
        tolerance        1e-06;
        relTol           0;
    };
}

PISO
{
    nCorrectors 3;
    nNonOrthogonalCorrectors 1;
}

SIMPLE
{
    nNonOrthogonalCorrectors  1;

    residualControl
    {
         p                       1e-9;
         U                       1e-9;
    }
}

PIMPLE
{
    nCorrectors 3;
    nOuterCorrectors 100;
    nNonOrthogonalCorrectors 1;

    residualControl
    {
    	U
        {
                tolerance  1e-6;
                relTol      0;
        }
        p
        {
                tolerance  1e-6;
                relTol      0;
        }
    }
}

relaxationFactors
{
    equations
    {
        U 0.4;
        UFinal 1;
    }
    fields
    {
        p 0.4;
    }
}

